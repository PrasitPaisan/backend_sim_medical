# backend environment variables
PORT=3000

# Dispensing machine SOAP endpoints — required for any send-to-machine call
# (medicines, prescriptions, department sync, machine status). Missing these
# does not crash the server, but every such call will report failure.
MACHINE_PATH_RB1500=http://<rb1500-host>:<port>/WebService.asmx
MACHINE_PATH_NZP360=http://<nzp360-host>:<port>/RssServer.asmx

# PostgreSQL database connection
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=electronic_shell
DB_SCHEMA=public
DB_SYNC=false
# Set to true for managed Postgres providers that require SSL (Supabase,
# RDS, etc.) — leave false/unset for a local/Docker Postgres with no SSL.
DB_SSL=false
